{
  "productName": "Remarkable",
  "version": "0.1.0",
  "identifier": "com.remarkable.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Remarkable",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:"
    }
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": {
        "allow": [
          { "path": "$HOME/**" },
          { "path": "$DOCUMENT/**" },
          { "path": "$DESKTOP/**" }
        ]
      }
    },
    "shell": {
      "open": true
    }
  }
}
