{
  "name": "markthecrab",
  "version": "0.2.1",
  "private": true,
  "description": "A cross-platform markdown editor built with Tauri and Rust",
  "scripts": {
    "build:mascot": "node scripts/build-mascot.mjs",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:web": "node scripts/build-mascot.mjs && esbuild src/app.js --bundle --outdir=src/dist --format=esm --minify --splitting --external:./wasm/pkg/* --loader:.aff=text --loader:.dic=text && node scripts/copy-vendor.js",
    "build": "npm run build:web",
    "build:demo": "npm run build:wasm && npm run build:web",
    "dev": "node scripts/build-mascot.mjs && esbuild src/app.js --bundle --outdir=src/dist --format=esm --splitting --watch --sourcemap --external:./wasm/pkg/* --loader:.aff=text --loader:.dic=text",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@tauri-apps/api": "^2.10.1",
    "codemirror": "^6.0.2",
    "dictionary-en-us": "^2.2.1",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "nspell": "^2.1.5"
  }
}
